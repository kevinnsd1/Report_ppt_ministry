<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Dashboard Report</title>
    <style>
        @page {
            size: A4 portrait;
            margin: 0;
        }
        * {
            box-sizing: border-box;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #ffffff;
            width: 210mm;
            height: 297mm;
            color: #333;
        }
        .container {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        /* Header Section */
        .header {
            display: flex;
            height: 40mm;
            width: 100%;
            background-color: #00305F; /* Deeper blue */
            /* Mesh Pattern */
            background-image: 
                linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
            background-size: 15px 15px;
            position: relative;
            overflow: hidden;
            display: flex;
        }
        .header::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: radial-gradient(circle at 10% 50%, rgba(0, 120, 200, 0.3), transparent 70%);
            z-index: 1;
        }
        .header-content {
            position: relative;
            z-index: 10;
            flex: 1;
            padding-left: 15mm;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .header-logo-container {
            position: relative;
            z-index: 5;
            background-color: #ffffff;
            width: 28%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 5mm;
            /* Slanted left edge */
            clip-path: polygon(25% 0, 100% 0, 100% 100%, 0% 100%);
        }
        /* Blue slant accent at the top-right corner */
        .header-accent {
            position: absolute;
            top: 0;
            right: 0;
            width: 35%;
            height: 40%;
            background-color: #0076D4;
            clip-path: polygon(0 0, 100% 0, 100% 100%);
            z-index: 2;
        }
        .title {
            font-size: 28pt;
            font-weight: 800;
            margin: 0;
            text-transform: uppercase;
            color: #ffffff;
            letter-spacing: 0.5pt;
        }
        .subtitle {
            font-size: 11pt;
            color: rgba(255, 255, 255, 0.7);
            margin-top: 3mm;
            font-weight: 400;
        }
        .logo-img {
            max-width: 85%;
            max-height: 28mm;
            object-fit: contain;
        }

        /* Main Content */
        .content {
            flex: 1;
            display: flex;
            gap: 8mm;
            padding: 10mm 15mm;
            background-color: #ffffff;
        }
        .column {
            flex: 1;
            background-color: #F8F9FA;
            border-radius: 8pt;
            padding: 12pt;
            box-shadow: 0 2pt 4pt rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
        }
        .column-header {
            border-radius: 8pt 8pt 0 0;
            padding: 8pt 12pt;
            margin: -12pt -12pt 12pt -12pt;
            color: white;
            font-weight: bold;
            font-size: 12pt;
            display: flex;
            align-items: center;
            gap: 6pt;
        }
        .col-socmed .column-header { background-color: #0088CC; }
        .col-online .column-header { background-color: #003366; }

        .chart-section-title {
            font-size: 10pt;
            font-weight: bold;
            color: #013463;
            margin-bottom: 8pt;
        }

        /* Ministry List & Bar Charts */
        .ministry-item {
            display: flex;
            align-items: center;
            margin-bottom: 8pt;
            gap: 8pt;
        }
        .min-logo {
            width: 20pt;
            height: 20pt;
            object-fit: contain;
            border-radius: 50%;
        }
        .min-dot {
            width: 10pt;
            height: 10pt;
            border-radius: 50%;
        }
        .min-info {
            flex: 1;
            font-size: 8pt;
            line-height: 1.2;
            word-wrap: break-word;
        }
        .min-chart-container {
            width: 40%;
            display: flex;
            align-items: center;
            gap: 4pt;
        }
        .bar-bg {
            flex: 1;
            height: 8pt;
            background-color: transparent;
            display: flex;
            align-items: center;
        }
        .bar-fill {
            height: 100%;
            border-radius: 2pt;
        }
        .val-box {
            font-size: 7.5pt;
            padding: 1pt 4pt;
            border: 0.5pt solid #ccc;
            border-radius: 2pt;
            background: white;
            min-width: 25pt;
            text-align: center;
        }

        /* Sorotan Section */
        .sorotan-title {
            font-size: 11pt;
            font-weight: bold;
            color: #013463;
            margin: 15pt 0 10pt 0;
        }
        .sorotan-item {
            display: flex;
            gap: 10pt;
            margin-bottom: 12pt;
        }
        .sorotan-text {
            flex: 1;
        }
        .sorotan-alias {
            font-size: 9pt;
            font-weight: bold;
            margin-bottom: 2pt;
        }
        .sorotan-desc {
            font-size: 8.5pt;
            color: #444;
            line-height: 1.4;
        }
        .link-icon {
            color: #0088CC;
            font-size: 12pt;
        }

        /* Footer */
        .footer {
            height: 15mm;
            padding: 0 15mm;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 8pt;
            color: #999;
            border-top: 1pt solid #eee;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header Section -->
        <div class="header">
            <div class="header-accent"></div>
            <div class="header-content">
                <h1 class="title"><%= meta.title %></h1>
                <div class="subtitle"><%= meta.subtitle %></div>
            </div>
            <div class="header-logo-container">
                <img src="<%= logoPath %>" class="logo-img">
            </div>
        </div>

        <!-- Content Area -->
        <div class="content">
            <% 
            const columns = [
                { data: leftCol, class: 'col-socmed', icon: '📱' },
                { data: rightCol, class: 'col-online', icon: '🌐' }
            ];
            
            // Fixed colors to match the previous design
            const SOCMED_COLORS = ['#0088CC', '#28A745', '#343A40', '#DAA520', '#FFD700'];
            const ONLINE_COLORS = ['#0088CC', '#28A745', '#17A2B8', '#28A745', '#FFC107'];

            for (let colIdx = 0; colIdx < columns.length; colIdx++) { 
                const col = columns[colIdx];
                const dotColors = colIdx === 0 ? SOCMED_COLORS : ONLINE_COLORS;
                const maxValue = Math.max(...col.data.items.map(i => i.value));
            %>
            <div class="column <%= col.class %>">
                <div class="column-header">
                    <span><%= col.icon %></span> <%= col.data.title %>
                </div>
                
                <div class="chart-section-title"><%= col.data.chartTitle %></div>
                
                <% 
                for (let idx = 0; idx < col.data.items.length; idx++) { 
                    const item = col.data.items[idx];
                    const color = dotColors[idx % dotColors.length];
                    const barWidth = (item.value / maxValue) * 100;
                %>
                <div class="ministry-item">
                    <% if (item.logoUrl) { %>
                        <img src="<%= item.logoUrl %>" class="min-logo">
                    <% } else { %>
                        <div class="min-dot" style="background-color: <%= color %>"></div>
                    <% } %>
                    <div class="min-info"><%- item.name.replace(/\n/g, '<br>') %></div>
                    <div class="min-chart-container">
                        <div class="bar-bg">
                            <div class="bar-fill" style="width: <%= barWidth %>%; background-color: <%= color %>"></div>
                        </div>
                        <div class="val-box"><%= item.value.toLocaleString('id-ID') %></div>
                    </div>
                </div>
                <% } %>

                <div style="text-align: center; font-size: 7pt; color: #999; margin: 8pt 0; font-style: italic;">
                    *Porsi percakapan dari 5 Kementerian dengan Pemberitaan tertinggi
                </div>
                <hr style="border: none; border-top: 0.5pt solid #ddd; width: 100%; margin: 5pt 0;">

                <div class="sorotan-title">Sorotan <%= col.data.title %></div>
                <% 
                for (let idx = 0; idx < col.data.items.length; idx++) { 
                    const item = col.data.items[idx];
                    const color = dotColors[idx % dotColors.length];
                %>
                <div class="sorotan-item">
                    <% if (item.logoUrl) { %>
                        <img src="<%= item.logoUrl %>" class="min-logo" style="width: 24pt; height: 24pt;">
                    <% } else { %>
                        <div class="min-dot" style="background-color: <%= color %>; width: 24pt; height: 24pt;"></div>
                    <% } %>
                    <div class="sorotan-text">
                        <div class="sorotan-alias"><%= item.alias %></div>
                        <div class="sorotan-desc"><%= item.text %></div>
                    </div>
                    <div class="link-icon">🔗</div>
                </div>
                <% } %>
            </div>
            <% } %>
        </div>

        <!-- Footer -->
        <div class="footer">
            <%= meta.footerText %>
        </div>
    </div>
</body>
</html>
